# ==============================================
# ModelScope API 配置（主要用于 LLM 调用）
# ==============================================
MODELSCOPE_API_KEY=your-modelscope-api-key-here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ==============================================
# DeepSeek API 配置（可选，如果使用 DeepSeek）
# ==============================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ==============================================
# Embedding 模型配置
# ==============================================
EMBEDDING_API_KEY=your-modelscope-api-key-here
EMBEDDING_BASE_URL=https://api-inference.modelscope.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# ==============================================
# 数据库配置
# ==============================================
DB_PATH=./DB/mimic_iv.sqlite

# ==============================================
# 检索索引配置（可选）
# ==============================================
VALUE_INDICES_PATH=./DB_faiss_indices/mimic_iv/mimic_iv_columnwise_embeddings_faiss_indices.bin
VALUE_METADATA_PATH=./DB_faiss_indices/mimic_iv/mimic_iv_columnwise_embeddings_metadata.pkl
KB_INDICES_PATH=./DB_faiss_indices/KB/KB_columnwise_embeddings_faiss_indices.bin
KB_METADATA_PATH=./DB_faiss_indices/KB/KB_columnwise_embeddings_metadata.pkl

# ==============================================
# 其他配置
# ==============================================
MAX_SQL_RETRIES=3
MAX_TURNS=10
